digraph SSB_Import {
  rankdir=BT;
  graph [bgcolor="#fafafa", pad=0.5, nodesep=0.5, ranksep=0.9, fontname="Helvetica"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11];
  edge  [color="#666666", arrowsize=0.7];

  // Foundation
  Defs [label="Defs.lean\n280 LOC",
        fillcolor="#cfe2f3", color="#1f4e79", penwidth=4,
        width=1.0, height=0.7];

  // Theorems (synthesis — headline results)
  T1 [label="Theorem1\n152 LOC",
      fillcolor="#fff2cc", color="#996600", penwidth=1.5,
      width=0.8, height=0.6];
  T2 [label="Theorem2\n154 LOC",
      fillcolor="#fff2cc", color="#996600", penwidth=1,
      width=0.8, height=0.6];
  T3 [label="Theorem3\n121 LOC",
      fillcolor="#fff2cc", color="#996600", penwidth=1,
      width=0.7, height=0.5];
  T4 [label="Theorem4\n275 LOC",
      fillcolor="#fff2cc", color="#996600", penwidth=1.5,
      width=1.0, height=0.7];

  // Strong variants
  T1S [label="Theorem1_Strong\n101 LOC",
       fillcolor="#fff2cc", color="#996600", penwidth=1,
       width=0.8, height=0.5];
  T4S [label="Theorem4_Strong\n108 LOC",
       fillcolor="#fff2cc", color="#996600", penwidth=1,
       width=0.8, height=0.5];

  // Edges
  T1  -> Defs;
  T2  -> Defs;
  T3  -> Defs;
  T4  -> Defs;
  T1S -> Defs;
  T1S -> T1;
  T4S -> Defs;
  T4S -> T4;

  // ───────── Legend ─────────
  legend [shape=plaintext, label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="4" CELLPADDING="4"
           COLOR="#bbbbbb" BGCOLOR="#ffffff">
      <TR><TD COLSPAN="2" ALIGN="LEFT"><B>Legend</B></TD></TR>
      <TR><TD BGCOLOR="#f4cccc" WIDTH="22" HEIGHT="14"></TD>
          <TD ALIGN="LEFT">god-module (multi-cluster)</TD></TR>
      <TR><TD BGCOLOR="#cfe2f3" WIDTH="22" HEIGHT="14"></TD>
          <TD ALIGN="LEFT">foundation (heavy fan-in)</TD></TR>
      <TR><TD BGCOLOR="#fff2cc" WIDTH="22" HEIGHT="14"></TD>
          <TD ALIGN="LEFT">synthesis (headline / glue)</TD></TR>
      <TR><TD BGCOLOR="#efefef" WIDTH="22" HEIGHT="14"></TD>
          <TD ALIGN="LEFT">helper (single-cluster lemmas)</TD></TR>
      <TR><TD BGCOLOR="#ffffff" WIDTH="22" HEIGHT="14"><FONT POINT-SIZE="10">┄┄</FONT></TD>
          <TD ALIGN="LEFT">orphan / stub (check intent)</TD></TR>
      <TR><TD COLSPAN="2"><FONT POINT-SIZE="10">────────────</FONT></TD></TR>
      <TR><TD COLSPAN="2" ALIGN="LEFT"><FONT POINT-SIZE="10">node size ∝ LOC</FONT></TD></TR>
      <TR><TD COLSPAN="2" ALIGN="LEFT"><FONT POINT-SIZE="10">border thickness ∝ fan-in<BR/>(downstream invalidation cost)</FONT></TD></TR>
    </TABLE>
  >];
}
