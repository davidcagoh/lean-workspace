// JEPA.lean — cluster-summary view.
// Each node = a proposed split file. Size ∝ LOC. Edge thickness ∝ # math edges crossing that boundary.
// "If we split JEPA.lean along these lines, this is the resulting import graph."

digraph JEPA_ClusterSummary {
  rankdir=BT;
  graph [bgcolor="#fafafa", pad=0.6, nodesep=0.6, ranksep=1.2,
         fontname="Helvetica", splines=true];
  node  [shape=box, style="rounded,filled", fontname="Helvetica",
         fontsize=11, margin="0.14,0.09"];
  edge  [arrowsize=0.7, fontname="Helvetica", fontsize=9];

  // Sub-clusters (proposed split files)
  Core [label=<<B>Core</B><BR/><FONT POINT-SIZE="10">definitions + operators</FONT><BR/><FONT POINT-SIZE="9" COLOR="#666666">13 decls · ~110 LOC</FONT>>,
        fillcolor="#cfe2f3", color="#1f4e79", penwidth=4,
        width=1.6, height=0.9];

  QuasiStatic [label=<<B>QuasiStatic</B><BR/><FONT POINT-SIZE="9" COLOR="#666666">4 decls · ~235 LOC</FONT>>,
               fillcolor="#d9ead3", color="#38761d",
               width=1.2, height=0.6];

  CriticalTime [label=<<B>CriticalTime</B><BR/><FONT POINT-SIZE="9" COLOR="#666666">2 decls · ~90 LOC</FONT>>,
                fillcolor="#fff2cc", color="#996600",
                width=1.1, height=0.5];

  Bernoulli [label=<<B>Bernoulli</B><BR/><FONT POINT-SIZE="9" COLOR="#666666">8 decls · ~195 LOC</FONT>>,
             fillcolor="#fce5cd", color="#b45f06",
             width=1.2, height=0.6];

  DiagAmpODE [label=<<B>DiagAmpODE</B><BR/><FONT POINT-SIZE="9" COLOR="#666666">3 decls · ~250 LOC</FONT>>,
              fillcolor="#f4cccc", color="#990000",
              width=1.2, height=0.6];

  FrobeniusHelpers [label=<<B>FrobeniusHelpers</B><BR/><FONT POINT-SIZE="9" COLOR="#666666">9 decls · ~210 LOC</FONT>>,
                    fillcolor="#ead1dc", color="#741b47",
                    width=1.4, height=0.65];

  EncoderConvergence [label=<<B>EncoderConvergence</B><BR/><FONT POINT-SIZE="9" COLOR="#666666">7 decls · ~378 LOC</FONT>>,
                      fillcolor="#d9d2e9", color="#351c75",
                      width=1.5, height=0.7];

  OffDiagFinal [label=<<B>OffDiagFinal</B><BR/><FONT POINT-SIZE="10">JEPA_rho_ordering (headline)</FONT><BR/><FONT POINT-SIZE="9" COLOR="#666666">6 decls · ~494 LOC</FONT>>,
                fillcolor="#ffe599", color="#7f6000", penwidth=3,
                width=1.7, height=0.9];

  // Edges: weight encoded in label + penwidth
  // Going INTO Core (the foundation pulls)
  edge [color="#7ba6c9"];
  OffDiagFinal       -> Core [label="20", penwidth=3.5];
  EncoderConvergence -> Core [label="11", penwidth=2.5];
  DiagAmpODE         -> Core [label="10", penwidth=2.3];
  FrobeniusHelpers   -> Core [label="9",  penwidth=2.1];
  QuasiStatic        -> Core [label="4",  penwidth=1.3];
  CriticalTime       -> Core [label="2",  penwidth=0.9];
  Bernoulli          -> Core [label="1",  penwidth=0.7];

  // Non-Core to non-Core edges — these are the "real" coupling
  edge [color="#444444"];
  EncoderConvergence -> FrobeniusHelpers [label="11 ⚠", penwidth=3.0, fontcolor="#cc0000"];
  EncoderConvergence -> QuasiStatic      [label="4",  penwidth=1.4];
  OffDiagFinal       -> QuasiStatic      [label="4",  penwidth=1.4];
  DiagAmpODE         -> Bernoulli        [label="3",  penwidth=1.2];
  OffDiagFinal       -> CriticalTime     [label="2",  penwidth=1.0];
  OffDiagFinal       -> EncoderConvergence [label="2", penwidth=1.0];
  DiagAmpODE         -> QuasiStatic      [label="1",  penwidth=0.7];
  DiagAmpODE         -> OffDiagFinal     [label="1",  penwidth=0.7, style=dashed];
  DiagAmpODE         -> EncoderConvergence [label="1", penwidth=0.7];
  FrobeniusHelpers   -> QuasiStatic      [label="1",  penwidth=0.7];
  FrobeniusHelpers   -> OffDiagFinal     [label="1",  penwidth=0.7, style=dashed];
  EncoderConvergence -> OffDiagFinal     [label="1",  penwidth=0.7, style=dashed];
  Bernoulli          -> OffDiagFinal     [label="1",  penwidth=0.7, style=dashed];

  // Legend
  legend [shape=plaintext, label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="4" CELLPADDING="4"
           COLOR="#bbbbbb" BGCOLOR="#ffffff">
      <TR><TD COLSPAN="2" ALIGN="LEFT"><B>If JEPA.lean were split…</B></TD></TR>
      <TR><TD COLSPAN="2" ALIGN="LEFT"><FONT POINT-SIZE="9">…this is the import graph it would<BR/>produce. Node size ∝ LOC, edge<BR/>thickness ∝ # math edges crossing.</FONT></TD></TR>
      <TR><TD COLSPAN="2"><FONT POINT-SIZE="9">────────────</FONT></TD></TR>
      <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10" COLOR="#7ba6c9"><B>━━</B></FONT></TD>
          <TD ALIGN="LEFT"><FONT POINT-SIZE="9">into Core (foundation pull)</FONT></TD></TR>
      <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10" COLOR="#444444"><B>━━</B></FONT></TD>
          <TD ALIGN="LEFT"><FONT POINT-SIZE="9">non-Core coupling</FONT></TD></TR>
      <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">┄┄</FONT></TD>
          <TD ALIGN="LEFT"><FONT POINT-SIZE="9">single-edge (probably noise)</FONT></TD></TR>
      <TR><TD COLSPAN="2"><FONT POINT-SIZE="9">────────────</FONT></TD></TR>
      <TR><TD COLSPAN="2" ALIGN="LEFT"><FONT POINT-SIZE="9"><B>Verdict:</B></FONT></TD></TR>
      <TR><TD COLSPAN="2" ALIGN="LEFT"><FONT POINT-SIZE="8">• Core is the natural foundation (heavy fan-in)</FONT></TD></TR>
      <TR><TD COLSPAN="2" ALIGN="LEFT"><FONT POINT-SIZE="8">• EncoderConvergence ↔ FrobeniusHelpers</FONT></TD></TR>
      <TR><TD COLSPAN="2" ALIGN="LEFT"><FONT POINT-SIZE="8">  are <B>tightly coupled (11 edges)</B> — consider</FONT></TD></TR>
      <TR><TD COLSPAN="2" ALIGN="LEFT"><FONT POINT-SIZE="8">  merging into one file</FONT></TD></TR>
      <TR><TD COLSPAN="2" ALIGN="LEFT"><FONT POINT-SIZE="8">• Other couplings ≤ 4 edges — clean splits</FONT></TD></TR>
      <TR><TD COLSPAN="2" ALIGN="LEFT"><FONT POINT-SIZE="8">• OffDiagFinal (494 LOC, headline) still large</FONT></TD></TR>
      <TR><TD COLSPAN="2" ALIGN="LEFT"><FONT POINT-SIZE="8">  even after split — proof itself is long</FONT></TD></TR>
    </TABLE>
  >];
}
