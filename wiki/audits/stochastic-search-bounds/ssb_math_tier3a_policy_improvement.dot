// Tier 3a — policy_improvement_reduces_hitting_time (Theorem 2)
// The only SSB theorem with a cross-file PROOF-STEP edge (red, into Defs).

digraph SSB_T2_BuildUp {
  rankdir=BT;
  graph [bgcolor="#fafafa", pad=0.5, nodesep=0.5, ranksep=0.95, fontname="Helvetica"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11,
         margin="0.12,0.07"];
  edge  [arrowsize=0.7];

  { rank=same;
    tier_def    [shape=plaintext, label=<<FONT POINT-SIZE="10" COLOR="#666666"><B>DEFINITIONS</B></FONT>>];
  }
  { rank=same;
    tier_lemma  [shape=plaintext, label=<<FONT POINT-SIZE="10" COLOR="#666666"><B>LEMMA</B></FONT>>];
  }
  { rank=same;
    tier_thm    [shape=plaintext, label=<<FONT POINT-SIZE="10" COLOR="#666666"><B>THEOREM</B></FONT>>];
  }
  tier_def -> tier_lemma -> tier_thm [style=invis];

  // ───── Definitions row ─────
  { rank=same;
    AOTree [label=<<B>AND-OR hypertree</B><BR/><FONT POINT-SIZE="9" COLOR="#666666">AOTree α</FONT>>,
            shape=hexagon, fillcolor="#cfe2f3", color="#1f4e79", fontsize=10];

    successProb [label=<<B>success probability under policy π</B><BR/><FONT POINT-SIZE="9" COLOR="#666666">successProb π t nid</FONT>>,
                 fillcolor="#cfe2f3", color="#1f4e79", fontsize=10];

    weightedSum [label=<<B>weighted-sum monotonicity (NNReal)</B><BR/><FONT POINT-SIZE="9">shift weight to good indices ⇒ sum ↑</FONT><BR/><FONT POINT-SIZE="9" COLOR="#666666">NNReal.weighted_sum_mono</FONT>>,
                 fillcolor="#cfe2f3", color="#1f4e79", fontsize=10];

    PolicyDom [label=<<B>policy domination</B><BR/><FONT POINT-SIZE="9">π' dominates π on correct children</FONT><BR/><FONT POINT-SIZE="9" COLOR="#666666">PolicyDominates (T2 structure)</FONT>>,
               shape=hexagon, fillcolor="#fff2cc", color="#996600", fontsize=10];

    tier_def;
  }

  // ───── Lemma row ─────
  { rank=same;
    lemma_mono [label=<<B>Lemma 2.1: success prob is monotone in policy</B><BR/><FONT POINT-SIZE="10">π ≼ π' ⇒  sp(π,t,nid)  ≤  sp(π',t,nid)</FONT><BR/><FONT POINT-SIZE="9" COLOR="#666666">successProb_mono</FONT>>,
                 fillcolor="#fff2cc", color="#996600", fontsize=11];
    tier_lemma;
  }

  // ───── Theorem row ─────
  { rank=same;
    thm_main [label=<<B>Theorem 2: policy improvement reduces hitting time</B><BR/><FONT POINT-SIZE="11">1 / sp(π',t,0)  ≤  1 / sp(π,t,0)</FONT><BR/><FONT POINT-SIZE="9" COLOR="#666666">policy_improvement_reduces_hitting_time</FONT>>,
              fillcolor="#fff2cc", color="#996600", penwidth=3,
              fontsize=13, width=3.6, height=1.0];
    tier_thm;
  }

  // ───── Definitional deps into lemma ─────
  edge [color="#1f4e79", penwidth=1.4];
  AOTree      -> lemma_mono;
  successProb -> lemma_mono;
  PolicyDom   -> lemma_mono [color="#996600"];

  // ───── Proof-step cross-file edge (the unique-in-SSB one) ─────
  edge [color="#990000", penwidth=2.8, style=solid];
  weightedSum -> lemma_mono [label="  applied in proof", fontsize=10, fontcolor="#990000"];

  // ───── Lemma → theorem (within-file proof step) ─────
  lemma_mono  -> thm_main [label="  applied in proof", fontsize=10, fontcolor="#990000"];

  // ───── Legend ─────
  legend [shape=plaintext, label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="3" CELLPADDING="3"
           COLOR="#bbbbbb" BGCOLOR="#ffffff">
      <TR><TD COLSPAN="2" ALIGN="LEFT"><B>Per-theorem build-up</B></TD></TR>
      <TR><TD COLSPAN="2" ALIGN="LEFT"><FONT POINT-SIZE="9">read bottom → top</FONT></TD></TR>
      <TR><TD COLSPAN="2"><FONT POINT-SIZE="9">────────────</FONT></TD></TR>
      <TR><TD BGCOLOR="#cfe2f3" WIDTH="18" HEIGHT="12"></TD>
          <TD ALIGN="LEFT"><FONT POINT-SIZE="9">from Defs.lean</FONT></TD></TR>
      <TR><TD BGCOLOR="#fff2cc" WIDTH="18" HEIGHT="12"></TD>
          <TD ALIGN="LEFT"><FONT POINT-SIZE="9">from Theorem2.lean</FONT></TD></TR>
      <TR><TD COLSPAN="2"><FONT POINT-SIZE="9">────────────</FONT></TD></TR>
      <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10" COLOR="#990000"><B>━━</B></FONT></TD>
          <TD ALIGN="LEFT"><FONT POINT-SIZE="9">proof-step (lemma applied)</FONT></TD></TR>
      <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10" COLOR="#1f4e79"><B>──</B></FONT></TD>
          <TD ALIGN="LEFT"><FONT POINT-SIZE="9">definitional dep</FONT></TD></TR>
      <TR><TD COLSPAN="2"><FONT POINT-SIZE="9">────────────</FONT></TD></TR>
      <TR><TD ALIGN="LEFT" COLSPAN="2"><FONT POINT-SIZE="9"><B>Note:</B> the red edge from<BR/>Defs (NNReal.weighted_sum_mono)<BR/>is the <I>only</I> cross-file<BR/>proof-step edge in SSB.</FONT></TD></TR>
    </TABLE>
  >];
}
